            st.session_state.cam = USBWebcamPipe(camera_idx=camera_idx, width=WIDTH, height=HEIGHT)
            st.session_state.current_camera_idx = camera_idx
        cam = st.session_state.cam
        
        # Timing trackers
        fps_history = []
        last_time = time.perf_counter()
        
        # Main run loop
        while run_stream:
            frame = cam.get_latest_frame()
            if frame is None:
                time.sleep(0.01)
                continue
            
            # Mirror selfie view if enabled
            if mirror_view:
                frame = cv2.flip(frame, 1)
            # Frame dimensions
            h, w = frame.shape[:2]
            # Draw top selection headers
            step = w // 5
            for i, col in enumerate(COLORS):
                x_start, x_end = i * step, (i + 1) * step
                if i == 4:
                    cv2.rectangle(frame, (x_start, 0), (x_end, 50), (200, 200, 200), -1)
                    cv2.putText(frame, "CLEAR", (x_start + 25, 33), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 0, 0), 2)
                else:
                    cv2.rectangle(frame, (x_start, 0), (x_end, 50), col, -1)
                    # Border highlights active color
                    if i == st.session_state.color_idx:
                        cv2.rectangle(frame, (x_start, 0), (x_end, 50), (255, 255, 255), 4)
            # Track frame count for skip-frame inference logic
            if 'frame_counter' not in st.session_state:
                st.session_state.frame_counter = 0
            st.session_state.frame_counter += 1
            if 'last_results' not in st.session_state:
                st.session_state.last_results = None
            # Process hand detection (downscaled to 320x240 and skipped based on slider configuration)
            if st.session_state.frame_counter % inference_skip == 0 or st.session_state.last_results is None:
                small_frame = cv2.resize(frame, (320, 240))
                rgb_small_frame = cv2.cvtColor(small_frame, cv2.COLOR_BGR2RGB)
                st.session_state.last_results = hands.process(rgb_small_frame)
            results = st.session_state.last_results
            current_mode = "Paused ⏸️"
            
            if results.multi_hand_landmarks:
                for idx, hand_landmarks in enumerate(results.multi_hand_landmarks):
                    lm = hand_landmarks.landmark
                    
                    # Determine hand label
                    hand_label = "Right"
                    if results.multi_handedness and idx < len(results.multi_handedness):
                        hand_label = results.multi_handedness[idx].classification[0].label
                        
                    # Classify active gesture
                    gesture = classify_gesture(lm, hand_label)
                    
                    # Convert normalized coords to pixels
                    x1, y1 = int(lm[8].x * w), int(lm[8].y * h)   # Index fingertip
                    x2, y2 = int(lm[12].x * w), int(lm[12].y * h) # Middle fingertip
                    
                    # Draw gesture label next to the hand on video overlay
                    x_wrist, y_wrist = int(lm[0].x * w), int(lm[0].y * h)
                    cv2.putText(frame, gesture, (x_wrist - 20, y_wrist + 30), cv2.FONT_HERSHEY_SIMPLEX, 0.75, (0, 255, 255), 2, cv2.LINE_AA)
                    # --- GESTURE ACTION MAPPINGS ---
                    
                    # Action 1: Peace Sign = Color Selection Mode
                    if gesture == "Peace Sign ✌️":
                        current_mode = "Selecting Color/Action 🎯"
                        st.session_state.xp, st.session_state.yp = 0, 0 # Reset drawing lines
                        
                        # Draw selection line/sight between fingertips
                        cv2.line(frame, (x1, y1), (x2, y2), COLORS[st.session_state.color_idx], 3)
                        cv2.circle(frame, (x1, y1), 8, COLORS[st.session_state.color_idx], -1)
                        cv2.circle(frame, (x2, y2), 8, COLORS[st.session_state.color_idx], -1)
                        
                        # Selection menu hit box
                        if y1 < 50:
                            selected_box = x1 // step
                            if selected_box == 4:
                                st.session_state.canvas = np.zeros((HEIGHT, WIDTH, 3), dtype=np.uint8)
                                st.session_state.xp, st.session_state.yp = 0, 0
                            else:
                                st.session_state.color_idx = selected_box
                                
                    # Action 2: Pointer = Standard Drawing Mode
                    elif gesture == "Pointer ☝️":
                        current_mode = "Drawing ✏️"
                        
                        # Draw pointer indicator
                        cv2.circle(frame, (x1, y1), brush_size + 4, COLORS[st.session_state.color_idx], -1)
                        cv2.circle(frame, (x1, y1), brush_size + 6, (255, 255, 255), 2)
                        if st.session_state.xp == 0 and st.session_state.yp == 0:
                            st.session_state.xp, st.session_state.yp = x1, y1
                        # Glitch protector (avoids drawing long warp lines if hand tracker jumps)
                        dist = math.hypot(x1 - st.session_state.xp, y1 - st.session_state.yp)
                        if dist < 100:
                            cv2.line(
                                st.session_state.canvas, 
                                (st.session_state.xp, st.session_state.yp), 
                                (x1, y1), 
                                COLORS[st.session_state.color_idx], 
                                brush_size
                            )
                        st.session_state.xp, st.session_state.yp = x1, y1
                        
                    # Action 3: Fist = Eraser Mode
                    elif gesture == "Fist ✊":
                        current_mode = "Eraser Mode 🧹"
                        st.session_state.xp, st.session_state.yp = 0, 0
                        
                        # Draw eraser circle indicator on the video frame
                        cv2.circle(frame, (x1, y1), brush_size * 4, (255, 255, 255), 2)
                        cv2.putText(frame, "ERASER", (x1 - 25, y1 - 15), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 255), 2, cv2.LINE_AA)
                        
                        # Wipe/delete pixels on the persistent canvas (black color = transparent overlay)
                        cv2.circle(st.session_state.canvas, (x1, y1), brush_size * 4, (0, 0, 0), -1)
                        
                    # Action 4: Rock On = Rainbow Glow Paint Mode
                    elif gesture == "Rock On 🤟":
                        current_mode = "Rainbow Paint Mode 🌈"
                        
                        # Update hue and convert HSL to BGR
                        if 'hue' not in st.session_state:
                            st.session_state.hue = 0.0
                        st.session_state.hue = (st.session_state.hue + 4) % 360
                        hsv_color = np.uint8([[[st.session_state.hue // 2, 255, 255]]]) # Hue is 0-179 in OpenCV
                        bgr_color = cv2.cvtColor(hsv_color, cv2.COLOR_HSV2BGR)[0][0]
                        rainbow_color = (int(bgr_color[0]), int(bgr_color[1]), int(bgr_color[2]))
                        
                        # Draw pointer indicator
                        cv2.circle(frame, (x1, y1), brush_size + 4, rainbow_color, -1)
                        cv2.circle(frame, (x1, y1), brush_size + 6, (255, 255, 255), 2)
                        if st.session_state.xp == 0 and st.session_state.yp == 0:
                            st.session_state.xp, st.session_state.yp = x1, y1
                        # Draw continuous rainbow line
                        dist = math.hypot(x1 - st.session_state.xp, y1 - st.session_state.yp)
                        if dist < 100:
                            cv2.line(
                                st.session_state.canvas, 
                                (st.session_state.xp, st.session_state.yp), 
                                (x1, y1), 
                                rainbow_color, 
                                brush_size
                            )
                        st.session_state.xp, st.session_state.yp = x1, y1
                        
                    else:
                        current_mode = f"Paused ({gesture}) ⏸️"
                        st.session_state.xp, st.session_state.yp = 0, 0
            else:
                st.session_state.xp, st.session_state.yp = 0, 0
            # Merge persistent drawing canvas with current frame (black pixels are transparent)
            paint_mask = st.session_state.canvas.any(axis=-1)
            frame[paint_mask] = st.session_state.canvas[paint_mask]
            # Compress to JPEG before sending over WebSocket to eliminate raw image network transfer bottlenecks
