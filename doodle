def get_cpu_temp():
    """Retrieves CPU temperature if available on Linux/Jetson."""
    if sys.platform.startswith('linux'):
        for i in range(5):
            path = f"/sys/class/thermal/thermal_zone{i}/temp"
            if os.path.exists(path):
                try:
                    with open(path, 'r') as f:
                        temp = float(f.read().strip()) / 1000.0
                        return f"{temp:.1f}°C"
                except Exception:
                    pass
    return "N/A"
def classify_gesture(lm, hand_label="Right"):
    """Classifies hand gesture based on geometric layout of landmarks"""
    # Finger states: True = Open, False = Closed
    # Tip coordinate compared to PIP joint coordinate
    index_up = lm[8].y < lm[6].y
    middle_up = lm[12].y < lm[10].y
    ring_up = lm[16].y < lm[14].y
    pinky_up = lm[20].y < lm[18].y
    # Thumb logic: check if extended away horizontally from index base (5)
    if hand_label == "Right":
        thumb_up = lm[4].x > lm[3].x and lm[4].x > lm[2].x
    else:
        thumb_up = lm[4].x < lm[3].x and lm[4].x < lm[2].x
    # 1. Fist: All closed
    if not thumb_up and not index_up and not middle_up and not ring_up and not pinky_up:
        return "Fist ✊"
    # 2. Open Palm: All open
    if thumb_up and index_up and middle_up and ring_up and pinky_up:
        return "Open Palm 🖐️"
    # 3. Peace Sign / Victory: Index and Middle open, Ring and Pinky closed
    if index_up and middle_up and not ring_up and not pinky_up:
        return "Peace Sign ✌️"
    # 4. Rock On / Spiderman (🤟): Thumb, Index, Pinky open, Middle and Ring closed
    if thumb_up and index_up and pinky_up and not middle_up and not ring_up:
        return "Rock On 🤟"
    # 5. Thumb Up: Only thumb open, others closed
    if thumb_up and not index_up and not middle_up and not ring_up and not pinky_up:
        return "Thumb Up 👍"
    # 6. OK Sign: Thumb and Index touching, others open
    d_thumb_index = math.hypot(lm[4].x - lm[8].x, lm[4].y - lm[8].y)
    if d_thumb_index < 0.06 and middle_up and ring_up and pinky_up:
        return "OK Sign 👌"
    # 7. Pointer: Only index open
    if index_up and not middle_up and not ring_up and not pinky_up:
        return "Pointer ☝️"
    return "Unknown Gesture 🤔"
