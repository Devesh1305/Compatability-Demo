            video_placeholder.image(jpeg_buffer.tobytes(), use_container_width=True)
            # Performance HUD metrics update
            now = time.perf_counter()
            fps = 1.0 / (now - last_time) if (now - last_time) > 0 else 0
            last_time = now
            fps_history.append(fps)
            if len(fps_history) > 30:
                fps_history.pop(0)
            avg_fps = np.mean(fps_history)
            fps_placeholder.markdown(f"""
                <div class="metric-container">
                    <div class="metric-label">Pipeline Frame Rate</div>
                    <div class="metric-value">{avg_fps:.1f} FPS</div>
                    <div class="metric-sub">MediaPipe + OpenCV Processing</div>
                </div>
            """, unsafe_allow_html=True)
            
            mode_placeholder.markdown(f"""
                <div class="metric-container">
                    <div class="metric-label">Active State</div>
                    <div class="metric-value" style="color: #0984e3;">{current_mode}</div>
                    <div class="metric-sub">Derived from finger landmark configuration</div>
                </div>
            """, unsafe_allow_html=True)
            active_col = COLOR_NAMES[st.session_state.color_idx]
            rgb_col = COLORS[st.session_state.color_idx]
            active_color_placeholder.markdown(f"""
                <div class="metric-container">
                    <div class="metric-label">Brush Color</div>
                    <div class="metric-value" style="color: rgb{rgb_col};">{active_col}</div>
                    <div class="metric-sub">Brush Size: {brush_size} px</div>
                </div>
            """, unsafe_allow_html=True)
            time.sleep(0.001)
    else:
        st.info("💡 Check the box above to start the webcam pipeline.")
        # Cleanup camera thread on stop
        if 'cam' in st.session_state and st.session_state.cam is not None:
            st.session_state.cam.close()
